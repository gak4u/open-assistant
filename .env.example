# --- LLM provider ---
# Pick one of: anthropic | claude-cli | ollama (auto-detected if unset)
OA_LLM_PROVIDER=

# Required for the Anthropic SDK backend
ANTHROPIC_API_KEY=

# Model selection (defaults shown)
OA_MODEL=claude-sonnet-4-20250514
OA_MAX_TOKENS=4096

# When using the `claude-cli` provider, override which model the CLI uses
OA_CLAUDE_CLI_MODEL=

# --- Ollama fallback (optional) ---
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_MODEL=llama3.2

# --- FalkorDB / Redis ---
FALKORDB_HOST=127.0.0.1
FALKORDB_PORT=6379
FALKORDB_PASSWORD=
FALKORDB_GRAPH=open_assistant

# --- Daemon ---
OA_DAEMON_HOST=127.0.0.1
OA_DAEMON_PORT=7338

# --- Agent runner ---
# Path to a writable scratch dir for spawned sub-agents
OA_AGENT_WORKDIR=/tmp/open-assistant-agents
