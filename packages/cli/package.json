  },
  "dependencies": {
    "@open-assistant/agent": "workspace:*",
    "@open-assistant/core": "workspace:*",
    "@open-assistant/memory": "workspace:*",
    "commander": "^12.1.0",
    "dotenv": "^16.4.7",
    "kleur": "^4.1.5"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "typescript": "^5.7.2"
  }
