{
  "name": "open-assistant",
  "version": "0.1.0",
  "private": true,
  "description": "Self-hostable, privacy-first AI assistant daemon with persistent graph memory",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "build": "pnpm -r --filter='./packages/*' --filter='./apps/*' build",
    "dev": "pnpm --filter @open-assistant/daemon dev",
    "cli": "pnpm --filter @open-assistant/cli start",
    "mcp": "pnpm --filter @open-assistant/mcp-server start",
    "typecheck": "pnpm -r typecheck",
    "clean": "pnpm -r exec rm -rf dist node_modules .next"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  },
  "packageManager": "pnpm@9.15.0",
  "engines": {
    "node": ">=20"
  }
}
